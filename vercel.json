{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/football-analyser/browser",
  "functions": {
    "api/**/*.ts": {}
  },
  "rewrites": [
    {
      "source": "/api/football/:path*",
      "destination": "/api/football?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
