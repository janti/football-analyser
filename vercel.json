{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/football-analyser/browser",
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}
