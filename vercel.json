{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/football-analyser/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/football$",
      "dest": "/api/football"
    },
    {
      "src": "^/api/football/(.*)$",
      "dest": "/api/football?path=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}
